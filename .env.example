# MoveCRM — exemple de configuration (copier vers .env et remplir)
# Base de données MySQL / MariaDB
DB_PLATFORM=Mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=movecrm
DB_USER=movecrm
DB_PASSWORD=changeme

# Admin EspoCRM (créé à l'installation)
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# Application
SITE_URL=http://localhost:8080
DEFAULT_LANG=fr_FR
