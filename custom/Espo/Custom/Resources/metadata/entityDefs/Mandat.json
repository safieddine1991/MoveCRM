{
    "fields": {
        "name": {
            "type": "varchar",
            "required": true,
            "pattern": "$noBadCharacters"
        },
        "mandateType": {
            "type": "enum",
            "options": ["Simple", "Exclusif", "Semi-exclusif"],
            "default": "Simple",
            "audited": true
        },
        "status": {
            "type": "enum",
            "options": ["Actif", "Expire", "Resilie", "Termine"],
            "default": "Actif",
            "displayAsLabel": true,
            "labelType": "state",
            "style": {
                "Actif": "success",
                "Expire": "warning",
                "Resilie": "danger",
                "Termine": "info"
            },
            "audited": true
        },
        "startDate": {
            "type": "date",
            "audited": true
        },
        "endDate": {
            "type": "date",
            "audited": true
        },
        "commissionRate": {
            "type": "float",
            "min": 0,
            "max": 100
        },
        "commissionAmount": {
            "type": "currency",
            "min": 0,
            "decimal": false
        },
        "description": {
            "type": "text"
        },
        "bien": {
            "type": "link"
        },
        "proprietaire": {
            "type": "link"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "assignedUser": {
            "type": "link",
            "required": false,
            "view": "views/fields/assigned-user"
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams"
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "bien": {
            "type": "belongsTo",
            "entity": "Bien",
            "foreign": "mandats"
        },
        "proprietaire": {
            "type": "belongsTo",
            "entity": "Proprietaire",
            "foreign": "mandats"
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc"
    },
    "indexes": {
        "status": {
            "columns": ["status", "deleted"]
        },
        "assignedUser": {
            "columns": ["assignedUserId", "deleted"]
        }
    }
}
