{
    "fields": {
        "name": {
            "type": "varchar",
            "required": true,
            "pattern": "$noBadCharacters"
        },
        "status": {
            "type": "enum",
            "options": ["Planifiee", "Realisee", "Annulee", "Sans suite"],
            "default": "Planifiee",
            "displayAsLabel": true,
            "labelType": "state",
            "style": {
                "Realisee": "success",
                "Annulee": "danger",
                "Sans suite": "info"
            },
            "audited": true
        },
        "dateStart": {
            "type": "datetime",
            "audited": true
        },
        "dateEnd": {
            "type": "datetime"
        },
        "outcome": {
            "type": "enum",
            "options": ["", "Interesse", "Offre", "Refus", "A recontacter"],
            "default": "",
            "style": {
                "Interesse": "primary",
                "Offre": "success",
                "Refus": "danger",
                "A recontacter": "warning"
            }
        },
        "feedback": {
            "type": "text"
        },
        "bien": {
            "type": "link"
        },
        "acquereur": {
            "type": "link"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "assignedUser": {
            "type": "link",
            "required": false,
            "view": "views/fields/assigned-user"
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams"
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "bien": {
            "type": "belongsTo",
            "entity": "Bien",
            "foreign": "visits"
        },
        "acquereur": {
            "type": "belongsTo",
            "entity": "Acquereur",
            "foreign": "visits"
        }
    },
    "collection": {
        "orderBy": "dateStart",
        "order": "desc"
    },
    "indexes": {
        "status": {
            "columns": ["status", "deleted"]
        },
        "assignedUser": {
            "columns": ["assignedUserId", "deleted"]
        },
        "dateStart": {
            "columns": ["dateStart", "deleted"]
        }
    }
}
